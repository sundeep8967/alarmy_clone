[
  {
    "id": "a1f0c9e2-3b4d-4a6e-8f10-1a2b3c4d5e6f",
    "speaker": "",
    "text": "Sigue adelante"
  },
  {
    "id": "b2e1f0a3-4c5d-6b7e-9a20-2b3c4d5e6f70",
    "speaker": "",
    "text": "Eres suficiente"
  },
  {
    "id": "c3d2e1b4-5d6e-7c8f-a130-3c4d5e6f7081",
    "speaker": "",
    "text": "Sueña en grande"
  },
  {
    "id": "d4c3b2e5-6e7f-8d9a-b240-4d5e6f708192",
    "speaker": "",
    "text": "Hoy será bueno"
  },
  {
    "id": "e5d4c3f6-7f80-9e0a-c350-5e6f708192a3",
    "speaker": "",
    "text": "Sonríe ahora"
  },
  {
    "id": "f6e5d4a7-8091-a01b-d460-6f708192a3b4",
    "speaker": "",
    "text": "Mantén la calma"
  },
  {
    "id": "07f6e5b8-91a2-b12c-e570-708192a3b4c5",
    "speaker": "",
    "text": "Siente la paz"
  },
  {
    "id": "18a7f6c9-a2b3-c23d-f680-8192a3b4c5d6",
    "speaker": "",
    "text": "Confía en ti"
  },
  {
    "id": "29b8a7da-b3c4-d34e-0790-92a3b4c5d6e7",
    "speaker": "",
    "text": "Eres valioso"
  },
  {
    "id": "3ac9b8eb-c4d5-e45f-18a0-a3b4c5d6e7f8",
    "speaker": "",
    "text": "Disfruta el día"
  },
  {
    "id": "4bdae9fc-d5e6-f560-29b0-b4c5d6e7f809",
    "speaker": "",
    "text": "Todo irá bien"
  },
  {
    "id": "5cebfa0d-e6f7-0671-3ac0-c5d6e7f8091a",
    "speaker": "",
    "text": "Abraza el hoy"
  },
  {
    "id": "6dfc0b1e-f708-1782-4bd0-d6e7f8091a2b",
    "speaker": "",
    "text": "Vive con fe"
  },
  {
    "id": "7e0d1c2f-0819-2893-5ce0-e7f8091a2b3c",
    "speaker": "",
    "text": "Sigue brillando"
  },
  {
    "id": "8f1e2d30-192a-39a4-6df0-f8091a2b3c4d",
    "speaker": "",
    "text": "Cree en ti"
  },
  {
    "id": "902f3e41-2a3b-4ab5-70a1-091a2b3c4d5e",
    "speaker": "",
    "text": "Hoy es tu día"
  },
  {
    "id": "a1304f52-3b4c-5bc6-81b1-1a2b3c4d5e6f",
    "speaker": "",
    "text": "Eres amado"
  },
  {
    "id": "b2415063-4c5d-6cd7-92c1-2b3c4d5e6f70",
    "speaker": "",
    "text": "Elige la alegría"
  },
  {
    "id": "c3526174-5d6e-7de8-a3d1-3c4d5e6f7081",
    "speaker": "",
    "text": "Mantén la fe"
  },
  {
    "id": "d4637285-6e7f-8ef9-b4e1-4d5e6f708192",
    "speaker": "",
    "text": "Vive el momento"
  },
  {
    "id": "e5748396-7f80-900a-c5f1-5e6f708192a3",
    "speaker": "",
    "text": "Hoy sonríe"
  },
  {
    "id": "f68594a7-8091-a11b-d601-6f708192a3b4",
    "speaker": "",
    "text": "Todo es posible"
  },
  {
    "id": "06a6a5b8-91a2-b22c-e711-708192a3b4c5",
    "speaker": "",
    "text": "Eres fuerte"
  },
  {
    "id": "17b7b6c9-a2b3-c33d-f821-8192a3b4c5d6",
    "speaker": "",
    "text": "Brilla ahora"
  },
  {
    "id": "28c8c7da-b3c4-d44e-0831-92a3b4c5d6e7",
    "speaker": "",
    "text": "Siente la luz"
  },
  {
    "id": "39d9d8eb-c4d5-e55f-1941-a3b4c5d6e7f8",
    "speaker": "",
    "text": "Cree en hoy"
  },
  {
    "id": "4aeae9fc-d5e6-f670-2a51-b4c5d6e7f809",
    "speaker": "",
    "text": "Eres especial"
  },
  {
    "id": "5bfbfa0d-e6f7-0781-3b61-c5d6e7f8091a",
    "speaker": "",
    "text": "Hoy brillarás"
  },
  {
    "id": "6c0c0b1e-f708-1892-4c71-d6e7f8091a2b",
    "speaker": "",
    "text": "Vive con amor"
  },
  {
    "id": "7d1d1c2f-0819-29a3-5d81-e7f8091a2b3c",
    "speaker": "",
    "text": "Siente gratitud"
  },
  {
    "id": "8e2e2d30-192a-3ab4-6e91-f8091a2b3c4d",
    "speaker": "",
    "text": "Hoy habrá calma"
  },
  {
    "id": "9f3f3e41-2a3b-4bc5-70a1-091a2b3c4d5e",
    "speaker": "",
    "text": "Confía en hoy"
  },
  {
    "id": "a0404f52-3b4c-5cd6-81b1-1a2b3c4d5e6f",
    "speaker": "",
    "text": "Eres brillante"
  },
  {
    "id": "b1515063-4c5d-6de7-92c1-2b3c4d5e6f70",
    "speaker": "",
    "text": "Todo es amor"
  },
  {
    "id": "c2626174-5d6e-7ef8-a3d1-3c4d5e6f7081",
    "speaker": "",
    "text": "Hoy habrá paz"
  },
  {
    "id": "d3737285-6e7f-8f09-b4e1-4d5e6f708192",
    "speaker": "",
    "text": "Sigue soñando"
  },
  {
    "id": "e4848396-7f80-901a-c5f1-5e6f708192a3",
    "speaker": "",
    "text": "Eres valiente"
  },
  {
    "id": "f59594a7-8091-a12b-d601-6f708192a3b4",
    "speaker": "",
    "text": "Hoy disfruta"
  },
  {
    "id": "06a6a5b8-91a2-b23c-e711-708192a3b4c5",
    "speaker": "",
    "text": "Elige la paz"
  },
  {
    "id": "17b7b6c9-a2b3-c34d-f821-8192a3b4c5d6",
    "speaker": "",
    "text": "Vive ligero"
  }
]
