[
  {
    "id": "c1a0b9e2-4d3f-4a6e-9f11-2b3c4d5e6f70",
    "speaker": "",
    "text": "今天一定行"
  },
  {
    "id": "d2b1c0a3-5e4f-6b7e-af21-3c4d5e6f7082",
    "speaker": "",
    "text": "没有什么难"
  },
  {
    "id": "e3c2d1b4-6f5f-7c8e-b032-4d5e6f708193",
    "speaker": "",
    "text": "不要放弃"
  },
  {
    "id": "f4d3e2c5-706f-8d9e-c143-5e6f708192a4",
    "speaker": "",
    "text": "现在是机会"
  },
  {
    "id": "05e4f3d6-817f-9e0e-d254-6f708192a3b5",
    "speaker": "",
    "text": "相信自己"
  },
  {
    "id": "16f504e7-928f-af1e-e365-708192a3b4c6",
    "speaker": "",
    "text": "大声笑一笑"
  },
  {
    "id": "270615f8-a39f-b02e-f476-8192a3b4c5d7",
    "speaker": "",
    "text": "梦想成真"
  },
  {
    "id": "38172609-b4af-c13e-0587-92a3b4c5d6e8",
    "speaker": "",
    "text": "充满笑容的一天"
  },
  {
    "id": "4928371a-c5bf-d24e-1698-a3b4c5d6e7f9",
    "speaker": "",
    "text": "今天是好日子"
  },
  {
    "id": "5a39482b-d6cf-e35e-27a9-b4c5d6e7f80a",
    "speaker": "",
    "text": "美好的早晨"
  },
  {
    "id": "6b4a593c-e7df-f46e-38ba-c5d6e7f8091b",
    "speaker": "",
    "text": "幸福会伴随"
  },
  {
    "id": "7c5b6a4d-f8ef-057e-49cb-d6e7f8091a2c",
    "speaker": "",
    "text": "今天特别好"
  },
  {
    "id": "8d6c7b5e-09ff-168e-5adc-e7f8091a2b3d",
    "speaker": "",
    "text": "好运会来到"
  },
  {
    "id": "9e7d8c6f-1a0f-279e-6bed-f8091a2b3c4e",
    "speaker": "",
    "text": "我足够好"
  },
  {
    "id": "af8e9d70-2b1f-38ae-7cfe-091a2b3c4d5f",
    "speaker": "",
    "text": "今天真快乐"
  },
  {
    "id": "b09fae81-3c2f-49be-8d0f-1a2b3c4d5e60",
    "speaker": "",
    "text": "我在发光"
  },
  {
    "id": "c1a0bf92-4d3f-5acf-9e10-2b3c4d5e6f71",
    "speaker": "",
    "text": "今天是我的日子"
  },
  {
    "id": "d2b1c0a3-5e4f-6b7e-af21-3c4d5e6f7092",
    "speaker": "",
    "text": "我被爱着"
  },
  {
    "id": "e3c2d1b4-6f5f-7c8e-b032-4d5e6f709193",
    "speaker": "",
    "text": "开怀笑一笑"
  },
  {
    "id": "f4d3e2c5-706f-8d9e-c143-5e6f709194a4",
    "speaker": "",
    "text": "好事会发生"
  },
  {
    "id": "05e4f3d6-817f-9e0e-d254-6f709195a3b5",
    "speaker": "",
    "text": "我做得很好"
  },
  {
    "id": "16f504e7-928f-af1e-e365-709196a3b4c6",
    "speaker": "",
    "text": "今天很幸福"
  },
  {
    "id": "270615f8-a39f-b02e-f476-709197a3b4c7",
    "speaker": "",
    "text": "我值得尊重"
  },
  {
    "id": "38172609-b4af-c13e-0587-709198a3b4c8",
    "speaker": "",
    "text": "今天充满笑声"
  },
  {
    "id": "4928371a-c5bf-d24e-1698-709199a3b4c9",
    "speaker": "",
    "text": "我是特别的"
  },
  {
    "id": "5a39482b-d6cf-e35e-27a9-70919aa3b4ca",
    "speaker": "",
    "text": "今天很温暖"
  },
  {
    "id": "6b4a593c-e7df-f46e-38ba-70919ba3b4cb",
    "speaker": "",
    "text": "快乐会找到我"
  },
  {
    "id": "7c5b6a4d-f8ef-057e-49cb-70919ca3b4cc",
    "speaker": "",
    "text": "我很勇敢"
  },
  {
    "id": "8d6c7b5e-09ff-168e-5adc-70919da3b4cd",
    "speaker": "",
    "text": "今天阳光灿烂"
  },
  {
    "id": "9e7d8c6f-1a0f-279e-6bed-70919ea3b4ce",
    "speaker": "",
    "text": "我心很平静"
  },
  {
    "id": "af8e9d70-2b1f-38ae-7cfe-70919fa3b4cf",
    "speaker": "",
    "text": "今天是快乐的"
  },
  {
    "id": "b09fae81-3c2f-49be-8d0f-7091a0a3b4d0",
    "speaker": "",
    "text": "我很幸福"
  },
  {
    "id": "c1a0bf92-4d3f-5acf-9e10-7091a1a3b4d1",
    "speaker": "",
    "text": "今天属于我"
  },
  {
    "id": "d2b1c0a3-5e4f-6b7e-af21-7091a2a3b4d2",
    "speaker": "",
    "text": "幸福会找到我"
  },
  {
    "id": "e3c2d1b4-6f5f-7c8e-b032-7091a3a3b4d3",
    "speaker": "",
    "text": "今天心情最好"
  },
  {
    "id": "f4d3e2c5-706f-8d9e-c143-7091a4a3b4d4",
    "speaker": "",
    "text": "我闪闪发亮"
  },
  {
    "id": "05e4f3d6-817f-9e0e-d254-7091a5a3b4d5",
    "speaker": "",
    "text": "今天笑容满满"
  },
  {
    "id": "16f504e7-928f-af1e-e365-7091a6a3b4d6",
    "speaker": "",
    "text": "我是勇敢的"
  },
  {
    "id": "270615f8-a39f-b02e-f476-7091a7a3b4d7",
    "speaker": "",
    "text": "今天很特别"
  },
  {
    "id": "38172609-b4af-c13e-0587-7091a8a3b4d8",
    "speaker": "",
    "text": "我相信自己"
  }
]
