010\u0008R\u001d\u0010\u001b\u001a\u0008\u0012\u0004\u0012\u00020\u00190\u00048\u0006\u00a2\u0006\u000c\n\u0004\u0008\u001a\u0010\u0007\u001a\u0004\u0008\u001a\u0010\u0008R\u001d\u0010\u001e\u001a\u0008\u0012\u0004\u0012\u00020\u001c0\u00048\u0006\u00a2\u0006\u000c\n\u0004\u0008\u001d\u0010\u0007\u001a\u0004\u0008\u001d\u0010\u0008R\u001d\u0010!\u001a\u0008\u0012\u0004\u0012\u00020\u001f0\u00048\u0006\u00a2\u0006\u000c\n\u0004\u0008 \u0010\u0007\u001a\u0004\u0008 \u0010\u0008R\u001d\u0010$\u001a\u0008\u0012\u0004\u0012\u00020\"0\u00048\u0006\u00a2\u0006\u000c\n\u0004\u0008#\u0010\u0007\u001a\u0004\u0008#\u0010\u0008R\u001d\u0010\'\u001a\u0008\u0012\u0004\u0012\u00020%0\u00048\u0006\u00a2\u0006\u000c\n\u0004\u0008&\u0010\u0007\u001a\u0004\u0008&\u0010\u0008R\u001d\u0010*\u001a\u0008\u0012\u0004\u0012\u00020(0\u00048\u0006\u00a2\u0006\u000c\n\u0004\u0008)\u0010\u0007\u001a\u0004\u0008)\u0010\u0008R\u001d\u0010-\u001a\u0008\u0012\u0004\u0012\u00020+0\u00048\u0006\u00a2\u0006\u000c\n\u0004\u0008,\u0010\u0007\u001a\u0004\u0008,\u0010\u0008R\u001d\u00100\u001a\u0008\u0012\u0004\u0012\u00020.0\u00048\u0006\u00a2\u0006\u000c\n\u0004\u0008/\u0010\u0007\u001a\u0004\u0008/\u0010\u0008R\u001d\u00103\u001a\u0008\u0012\u0004\u0012\u0002010\u00048\u0006\u00a2\u0006\u000c\n\u0004\u00082\u0010\u0007\u001a\u0004\u00082\u0010\u0008R\u001d\u00106\u001a\u0008\u0012\u0004\u0012\u0002040\u00048\u0006\u00a2\u0006\u000c\n\u0004\u00085\u0010\u0007\u001a\u0004\u00085\u0010\u0008R\u001d\u00109\u001a\u0008\u0012\u0004\u0012\u0002070\u00048\u0006\u00a2\u0006\u000c\n\u0004\u00088\u0010\u0007\u001a\u0004\u00088\u0010\u0008R\u001d\u0010<\u001a\u0008\u0012\u0004\u0012\u00020:0\u00048\u0006\u00a2\u0006\u000c\n\u0004\u0008;\u0010\u0007\u001a\u0004\u0008;\u0010\u0008R\u001d\u0010?\u001a\u0008\u0012\u0004\u0012\u00020=0\u00048\u0006\u00a2\u0006\u000c\n\u0004\u0008>\u0010\u0007\u001a\u0004\u0008>\u0010\u0008R\u001d\u0010B\u001a\u0008\u0012\u0004\u0012\u00020@0\u00048\u0006\u00a2\u0006\u000c\n\u0004\u0008A\u0010\u0007\u001a\u0004\u0008A\u0010\u0008R\u001d\u0010E\u001a\u0008\u0012\u0004\u0012\u00020C0\u00048\u0006\u00a2\u0006\u000c\n\u0004\u0008D\u0010\u0007\u001a\u0004\u0008D\u0010\u0008R\u001d\u0010H\u001a\u0008\u0012\u0004\u0012\u00020F0\u00048\u0006\u00a2\u0006\u000c\n\u0004\u0008G\u0010\u0007\u001a\u0004\u0008G\u0010\u0008R\u001d\u0010K\u001a\u0008\u0012\u0004\u0012\u00020I0\u00048\u0006\u00a2\u0006\u000c\n\u0004\u0008J\u0010\u0007\u001a\u0004\u0008J\u0010\u0008R\u001d\u0010N\u001a\u0008\u0012\u0004\u0012\u00020L0\u00048\u0006\u00a2\u0006\u000c\n\u0004\u0008M\u0010\u0007\u001a\u0004\u0008M\u0010\u0008R\u001d\u0010Q\u001a\u0008\u0012\u0004\u0012\u00020O0\u00048\u0006\u00a2\u0006\u000c\n\u0004\u0008P\u0010\u0007\u001a\u0004\u0008P\u0010\u0008R\u001d\u0010T\u001a\u0008\u0012\u0004\u0012\u00020R0\u00048\u0006\u00a2\u0006\u000c\n\u0004\u0008S\u0010\u0007\u001a\u0004\u0008S\u0010\u0008R\u001d\u0010W\u001a\u0008\u0012\u0004\u0012\u00020U0\u00048\u0006\u00a2\u0006\u000c\n\u0004\u0008V\u0010\u0007\u001a\u0004\u0008V\u0010\u0008R\u001d\u0010Z\u001a\u0008\u0012\u0004\u0012\u00020X0\u00048\u0006\u00a2\u0006\u000c\n\u0004\u0008Y\u0010\u0007\u001a\u0004\u0008Y\u0010\u0008R\u001d\u0010]\u001a\u0008\u0012\u0004\u0012\u00020[0\u00048\u0006\u00a2\u0006\u000c\n\u0004\u0008\\\u0010\u0007\u001a\u0004\u0008\\\u0010\u0008R\u001d\u0010`\u001a\u0008\u0012\u0004\u0012\u00020^0\u00048\u0006\u00a2\u0006\u000c\n\u0004\u0008_\u0010\u0007\u001a\u0004\u0008_\u0010\u0008R\u001d\u0010c\u001a\u0008\u0012\u0004\u0012\u00020a0\u00048\u0006\u00a2\u0006\u000c\n\u0004\u0008b\u0010\u0007\u001a\u0004\u0008b\u0010\u0008R\u001d\u0010f\u001a\u0008\u0012\u0004\u0012\u00020d0\u00048\u0006\u00a2\u0006\u000c\n\u0004\u0008e\u0010\u0007\u001a\u0004\u0008e\u0010\u0008R\u001d\u0010i\u001a\u0008\u0012\u0004\u0012\u00020g0\u00048\u0006\u00a2\u0006\u000c\n\u0004\u0008h\u0010\u0007\u001a\u0004\u0008h\u0010\u0008R\u001d\u0010l\u001a\u0008\u0012\u0004\u0012\u00020j0\u00048\u0006\u00a2\u0006\u000c\n\u0004\u0008k\u0010\u0007\u001a\u0004\u0008k\u0010\u0008R\u001d\u0010o\u001a\u0008\u0012\u0004\u0012\u00020m0\u00048\u0006\u00a2\u0006\u000c\n\u0004\u0008n\u0010\u0007\u001a\u0004\u0008n\u0010\u0008R\u001d\u0010r\u001a\u0008\u0012\u0004\u0012\u00020p0\u00048\u0006\u00a2\u0006\u000c\n\u0004\u0008q\u0010\u0007\u001a\u0004\u0008q\u0010\u0008R\u001d\u0010u\u001a\u0008\u0012\u0004\u0012\u00020s0\u00048\u0006\u00a2\u0006\u000c\n\u0004\u0008t\u0010\u0007\u001a\u0004\u0008t\u0010\u0008R\u001d\u0010x\u001a\u0008\u0012\u0004\u0012\u00020v0\u00048\u0006\u00a2\u0006\u000c\n\u0004\u0008w\u0010\u0007\u001a\u0004\u0008w\u0010\u0008R\u001d\u0010{\u001a\u0008\u0012\u0004\u0012\u00020y0\u00048\u0006\u00a2\u0006\u000c\n\u0004\u0008z\u0010\u0007\u001a\u0004\u0008z\u0010\u0008R\u001d\u0010~\u001a\u0008\u0012\u0004\u0012\u00020|0\u00048\u0006\u00a2\u0006\u000c\n\u0004\u0008}\u0010\u0007\u001a\u0004\u0008}\u0010\u0008R \u0010\u0081\u0001\u001a\u0008\u0012\u0004\u0012\u00020\u007f0\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u0080\u0001\u0010\u0007\u001a\u0005\u0008\u0080\u0001\u0010\u0008R!\u0010\u0084\u0001\u001a\t\u0012\u0005\u0012\u00030\u0082\u00010\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u0083\u0001\u0010\u0007\u001a\u0005\u0008\u0083\u0001\u0010\u0008R!\u0010\u0087\u0001\u001a\t\u0012\u0005\u0012\u00030\u0085\u00010\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u0086\u0001\u0010\u0007\u001a\u0005\u0008\u0086\u0001\u0010\u0008R!\u0010\u008a\u0001\u001a\t\u0012\u0005\u0012\u00030\u0088\u00010\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u0089\u0001\u0010\u0007\u001a\u0005\u0008\u0089\u0001\u0010\u0008R!\u0010\u008d\u0001\u001a\t\u0012\u0005\u0012\u00030\u008b\u00010\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u008c\u0001\u0010\u0007\u001a\u0005\u0008\u008c\u0001\u0010\u0008R!\u0010\u0090\u0001\u001a\t\u0012\u0005\u0012\u00030\u008e\u00010\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u008f\u0001\u0010\u0007\u001a\u0005\u0008\u008f\u0001\u0010\u0008R!\u0010\u0093\u0001\u001a\t\u0012\u0005\u0012\u00030\u0091\u00010\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u0092\u0001\u0010\u0007\u001a\u0005\u0008\u0092\u0001\u0010\u0008R!\u0010\u0096\u0001\u001a\t\u0012\u0005\u0012\u00030\u0094\u00010\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u0095\u0001\u0010\u0007\u001a\u0005\u0008\u0095\u0001\u0010\u0008R!\u0010\u0099\u0001\u001a\t\u0012\u0005\u0012\u00030\u0097\u00010\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u0098\u0001\u0010\u0007\u001a\u0005\u0008\u0098\u0001\u0010\u0008R!\u0010\u009c\u0001\u001a\t\u0012\u0005\u0012\u00030\u009a\u00010\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u009b\u0001\u0010\u0007\u001a\u0005\u0008\u009b\u0001\u0010\u0008R!\u0010\u009f\u0001\u001a\t\u0012\u0005\u0012\u00030\u009d\u00010\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u009e\u0001\u0010\u0007\u001a\u0005\u0008\u009e\u0001\u0010\u0008R!\u0010\u00a2\u0001\u001a\t\u0012\u0005\u0012\u00030\u00a0\u00010\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u00a1\u0001\u0010\u0007\u001a\u0005\u0008\u00a1\u0001\u0010\u0008R!\u0010\u00a5\u0001\u001a\t\u0012\u0005\u0012\u00030\u00a3\u00010\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u00a4\u0001\u0010\u0007\u001a\u0005\u0008\u00a4\u0001\u0010\u0008R!\u0010\u00a8\u0001\u001a\t\u0012\u0005\u0012\u00030\u00a6\u00010\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u00a7\u0001\u0010\u0007\u001a\u0005\u0008\u00a7\u0001\u0010\u0008R!\u0010\u00ab\u0001\u001a\t\u0012\u0005\u0012\u00030\u00a9\u00010\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u00aa\u0001\u0010\u0007\u001a\u0005\u0008\u00aa\u0001\u0010\u0008R!\u0010\u00ae\u0001\u001a\t\u0012\u0005\u0012\u00030\u00ac\u00010\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u00ad\u0001\u0010\u0007\u001a\u0005\u0008\u00ad\u0001\u0010\u0008R!\u0010\u00b1\u0001\u001a\t\u0012\u0005\u0012\u00030\u00af\u00010\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u00b0\u0001\u0010\u0007\u001a\u0005\u0008\u00b0\u0001\u0010\u0008R!\u0010\u00b4\u0001\u001a\t\u0012\u0005\u0012\u00030\u00b2\u00010\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u00b3\u0001\u0010\u0007\u001a\u0005\u0008\u00b3\u0001\u0010\u0008R!\u0010\u00b7\u0001\u001a\t\u0012\u0005\u0012\u00030\u00b5\u00010\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u00b6\u0001\u0010\u0007\u001a\u0005\u0008\u00b6\u0001\u0010\u0008R!\u0010\u00ba\u0001\u001a\t\u0012\u0005\u0012\u00030\u00b8\u00010\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u00b9\u0001\u0010\u0007\u001a\u0005\u0008\u00b9\u0001\u0010\u0008R!\u0010\u00bd\u0001\u001a\t\u0012\u0005\u0012\u00030\u00bb\u00010\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u00bc\u0001\u0010\u0007\u001a\u0005\u0008\u00bc\u0001\u0010\u0008R!\u0010\u00c0\u0001\u001a\t\u0012\u0005\u0012\u00030\u00be\u00010\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u00bf\u0001\u0010\u0007\u001a\u0005\u0008\u00bf\u0001\u0010\u0008R!\u0010\u00c3\u0001\u001a\t\u0012\u0005\u0012\u00030\u00c1\u00010\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u00c2\u0001\u0010\u0007\u001a\u0005\u0008\u00c2\u0001\u0010\u0008R!\u0010\u00c6\u0001\u001a\t\u0012\u0005\u0012\u00030\u00c4\u00010\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u00c5\u0001\u0010\u0007\u001a\u0005\u0008\u00c5\u0001\u0010\u0008R!\u0010\u00c9\u0001\u001a\t\u0012\u0005\u0012\u00030\u00c7\u00010\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u00c8\u0001\u0010\u0007\u001a\u0005\u0008\u00c8\u0001\u0010\u0008R!\u0010\u00cc\u0001\u001a\t\u0012\u0005\u0012\u00030\u00ca\u00010\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u00cb\u0001\u0010\u0007\u001a\u0005\u0008\u00cb\u0001\u0010\u0008R!\u0010\u00cf\u0001\u001a\t\u0012\u0005\u0012\u00030\u00cd\u00010\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u00ce\u0001\u0010\u0007\u001a\u0005\u0008\u00ce\u0001\u0010\u0008R!\u0010\u00d2\u0001\u001a\t\u0012\u0005\u0012\u00030\u00d0\u00010\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u00d1\u0001\u0010\u0007\u001a\u0005\u0008\u00d1\u0001\u0010\u0008R!\u0010\u00d5\u0001\u001a\t\u0012\u0005\u0012\u00030\u00d3\u00010\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u00d4\u0001\u0010\u0007\u001a\u0005\u0008\u00d4\