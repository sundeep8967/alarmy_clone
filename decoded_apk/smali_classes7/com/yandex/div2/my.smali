u0005\u0008\u00c0\u0002\u0010\u0008R!\u0010\u00c4\u0002\u001a\t\u0012\u0005\u0012\u00030\u00c2\u00020\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u00ba\u0002\u0010\u0007\u001a\u0005\u0008\u00c3\u0002\u0010\u0008R!\u0010\u00c7\u0002\u001a\t\u0012\u0005\u0012\u00030\u00c5\u00020\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u00bd\u0002\u0010\u0007\u001a\u0005\u0008\u00c6\u0002\u0010\u0008R!\u0010\u00ca\u0002\u001a\t\u0012\u0005\u0012\u00030\u00c8\u00020\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u00ae\u0002\u0010\u0007\u001a\u0005\u0008\u00c9\u0002\u0010\u0008R!\u0010\u00cd\u0002\u001a\t\u0012\u0005\u0012\u00030\u00cb\u00020\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u00b1\u0002\u0010\u0007\u001a\u0005\u0008\u00cc\u0002\u0010\u0008R!\u0010\u00d0\u0002\u001a\t\u0012\u0005\u0012\u00030\u00ce\u00020\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u00b4\u0002\u0010\u0007\u001a\u0005\u0008\u00cf\u0002\u0010\u0008R!\u0010\u00d3\u0002\u001a\t\u0012\u0005\u0012\u00030\u00d1\u00020\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u00c0\u0002\u0010\u0007\u001a\u0005\u0008\u00d2\u0002\u0010\u0008R!\u0010\u00d6\u0002\u001a\t\u0012\u0005\u0012\u00030\u00d4\u00020\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u00c3\u0002\u0010\u0007\u001a\u0005\u0008\u00d5\u0002\u0010\u0008R!\u0010\u00d9\u0002\u001a\t\u0012\u0005\u0012\u00030\u00d7\u00020\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u00c6\u0002\u0010\u0007\u001a\u0005\u0008\u00d8\u0002\u0010\u0008R!\u0010\u00dc\u0002\u001a\t\u0012\u0005\u0012\u00030\u00da\u00020\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u00c9\u0002\u0010\u0007\u001a\u0005\u0008\u00db\u0002\u0010\u0008R!\u0010\u00df\u0002\u001a\t\u0012\u0005\u0012\u00030\u00dd\u00020\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u00cc\u0002\u0010\u0007\u001a\u0005\u0008\u00de\u0002\u0010\u0008R!\u0010\u00e2\u0002\u001a\t\u0012\u0005\u0012\u00030\u00e0\u00020\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u00cf\u0002\u0010\u0007\u001a\u0005\u0008\u00e1\u0002\u0010\u0008R!\u0010\u00e4\u00