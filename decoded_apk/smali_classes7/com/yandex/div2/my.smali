u0012\u0005\u0012\u00030\u0080\r0\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u0081\r\u0010\u0007\u001a\u0005\u0008\u008e\u0007\u0010\u0008R!\u0010\u0085\r\u001a\t\u0012\u0005\u0012\u00030\u0083\r0\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u0084\r\u0010\u0007\u001a\u0005\u0008\u00f8\u000c\u0010\u0008R!\u0010\u0088\r\u001a\t\u0012\u0005\u0012\u00030\u0086\r0\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u0087\r\u0010\u0007\u001a\u0005\u0008\u00fb\u000c\u0010\u0008R!\u0010\u008b\r\u001a\t\u0012\u0005\u0012\u00030\u0089\r0\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u008a\r\u0010\u0007\u001a\u0005\u0008\u00fe\u000c\u0010\u0008R!\u0010\u008e\r\u001a\t\u0012\u0005\u0012\u00030\u008c\r0\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u008d\r\u0010\u0007\u001a\u0005\u0008\u0081\r\u0010\u0008R!\u0010\u0091\r\u001a\t\u0012\u0005\u0012\u00030\u008f\r0\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u0090\r\u0010\u0007\u001a\u0005\u0008\u0084\r\u0010\u0008R!\u0010\u0094\r\u001a\t\u0012\u0005\u0012\u00030\u0092\r0\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u0093\r\u0010\u0007\u001a\u0005\u0008\u0087\r\u0010\u0008R!\u0010\u0097\r\u001a\t\u0012\u0005\u0012\u00030\u0095\r0\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u0096\r\u0010\u0007\u001a\u0005\u0008\u008a\r\u0010\u0008R!\u0010\u009a\r\u001a\t\u0012\u0005\u0012\u00030\u0098\r0\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u0099\r\u0010\u0007\u001a\u0005\u0008\u008d\r\u0010\u0008R!\u0010\u009d\r\u001a\t\u0012\u0005\u0012\u00030\u009b\r0\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u009c\r\u0010\u0007\u001a\u0005\u0008\u0090\r\u0010\u0008R!\u0010\u00a0\r\u001a\t\u0012\u0005\u0012\u00030\u009e\r0\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u009f\r\u0010\u0007\u001a\u0005\u0008\u0093\r\u0010\u0008R!\u0010\u00a3\r\u001a\t\u0012\u0005\u0012\u00030\u00a1\r0\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u00a2\r\u0010\u0007\u001a\u0005\u0008\u0096\r\u0010\u0008R!\u0010\u00a6\r\u001a\t\u0012\u0005\u0012\u00030\u00a4\r0\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u00a5\r\u0010\u0007\u001a\u0005\u0008\u0099\r\u0010\u0008R!\u0010\u00a9\r\u001a\t\u0012\u0005\u0012\u00030\u00a7\r0\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u00a8\r\u0010\u0007\u001a\u0005\u0008\u009c\r\u0010\u0008R!\u0010\u00ac\r\u001a\t\u0012\u0005\u0012\u00030\u00aa\r0\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u00ab\r\u0010\u0007\u001a\u0005\u0008\u009f\r\u0010\u0008R!\u0010\u00af\r\u001a\t\u0012\u0005\u0012\u00030\u00ad\r0\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u00ae\r\u0010\u0007\u001a\u0005\u0008\u00a2\r\u0010\u0008R!\u0010\u00b2\r\u001a\t\u0012\u0005\u0012\u00030\u00b0\r0\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u00b1\r\u0010\u0007\u001a\u0005\u0008\u00a5\r\u0010\u0008R!\u0010\u00b5\r\u001a\t\u0012\u0005\u0012\u00030\u00b3\r0\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u00b4\r\u0010\u0007\u001a\u0005\u0008\u00a8\r\u0010\u0008R!\u0010\u00b8\r\u001a\t\u0012\u0005\u0012\u00030\u00b6\r0\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u00b7\r\u0010\u0007\u001a\u0005\u0008\u00ab\r\u0010\u0008R!\u0010\u00bb\r\u001a\t\u0012\u0005\u0012\u00030\u00b9\r0\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u00ba\r\u0010\u0007\u001a\u0005\u0008\u00ae\r\u0010\u0008R!\u0010\u00be\r\u001a\t\u0012\u0005\u0012\u00030\u00bc\r0\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u00bd\r\u0010\u0007\u001a\u0005\u0008\u00b1\r\u0010\u0008R!\u0010\u00c1\r\u001a\t\u0012\u0005\u0012\u00030\u00bf\r0\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u00c0\r\u0010\u0007\u001a\u0005\u0008\u00b4\r\u0010\u0008R!\u0010\u00c4\r\u001a\t\u0012\u0005\u0012\u00030\u00c2\r0\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u00c3\r\u0010\u0007\u001a\u0005\u0008\u00b7\r\u0010\u0008R!\u0010\u00c7\r\u001a\t\u0012\u0005\u0012\u00030\u00c5\r0\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u00c6\r\u0010\u0007\u001a\u0005\u0008\u00ba\r\u0010\u0008R!\u0010\u00ca\r\u001a\t\u0012\u0005\u0012\u00030\u00c8\r0\u00048\u0006\u00a2\u0006\u000e\n\u0005\u0008\u00c9\r\u0010\u0007\u001a\u0005\u0008\u00