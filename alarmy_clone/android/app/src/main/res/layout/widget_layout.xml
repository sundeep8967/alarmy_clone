<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="16dp"
    android:gravity="center_vertical">

    <!-- Top row: alarm icon + label -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/widget_mission_icon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/ic_lock_idle_alarm"
            android:contentDescription="Alarm" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="NEXT ALARM"
            android:textColor="#80FFFFFF"
            android:textSize="10sp"
            android:letterSpacing="0.12"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <!-- Large alarm time -->
    <TextView
        android:id="@+id/widget_alarm_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="07:00"
        android:textColor="#FFFFFF"
        android:textSize="36sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-light"
        android:letterSpacing="-0.03" />

    <!-- Mission type label -->
    <TextView
        android:id="@+id/widget_mission_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="Math Mission"
        android:textColor="#80FFFFFF"
        android:textSize="11sp"
        android:fontFamily="sans-serif" />

</LinearLayout>
