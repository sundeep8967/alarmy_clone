[
  {
    "id": "ddfabb20-b96e-45a8-8a91-32d8cdea9216",
    "speaker": "",
    "text": "My life is a gift."
  },
  {
    "id": "b9057aa9-f14b-44a0-94f4-11f0217cfdab",
    "speaker": "",
    "text": "I am delighted to be alive."
  },
  {
    "id": "f43b6fdc-9337-46ad-a6d6-2aac951d082c",
    "speaker": "",
    "text": "I receive love and happiness."
  },
  {
    "id": "b45c1f9c-c401-4863-9bdb-5120a8a21f60",
    "speaker": "",
    "text": "I am happy, joyful, and free."
  },
  {
    "id": "9e05fbf3-40cf-43fc-8f61-5d35f5575d4a",
    "speaker": "",
    "text": "I find joy in everything I do."
  },
  {
    "id": "d366a97f-1aa8-4f76-8df7-0b45afe17d44",
    "speaker": "",
    "text": "I know that there is always hope."
  },
  {
    "id": "da62e167-2c85-4552-88c7-52d6e9bd6464",
    "speaker": "",
    "text": "I am living the life of my dreams."
  },
  {
    "id": "a21c43b0-1ff8-405b-a84f-4ea0d01b81ad",
    "speaker": "",
    "text": "I feel grateful, happy, and loved."
  },
  {
    "id": "2d8e3289-4988-4093-bbca-ca57d4a0e31b",
    "speaker": "",
    "text": "I've decided that I am good enough."
  },
  {
    "id": "7f17a34c-69e1-4acc-b876-675f650d757f",
    "speaker": "",
    "text": "I am living my most authentic life."
  },
  {
    "id": "d0220d80-cd13-4ba5-af35-b9ed1685d3dd",
    "speaker": "",
    "text": "I am brimming with positivity today."
  },
  {
    "id": "7a521e23-4a60-49a6-92e5-0070bca13821",
    "speaker": "",
    "text": "I begin each day with a happy heart."
  },
  {
    "id": "112773cc-287a-4fb4-809f-fa40fe3e2110",
    "speaker": "",
    "text": "I am happy with the person I am today."
  },
  {
    "id": "a7f6222a-91b8-4581-b942-7a91c7e68323",
    "speaker": "",
    "text": "I am blessed with health and strength."
  },
  {
    "id": "f36e1532-2943-4dc5-822e-5b837b01a4f6",
    "speaker": "",
    "text": "I am committed to having a great life."
  },
  {
    "id": "b800a6db-3248-41a9-ae27-fac046c42140",
    "speaker": "",
    "text": "I am attracting abundance into my life."
  },
  {
    "id": "0aaaf779-8171-4973-a449-a4c98fcdcd73",
    "speaker": "",
    "text": "I make room for growth and possibility."
  },
  {
    "id": "bd773a5d-8e20-479f-a76e-a715d8d4731e",
    "speaker": "",
    "text": "I am a positive influence on the world."
  },
  {
    "id": "e5692284-62d6-4d09-bee5-6256dc279544",
    "speaker": "",
    "text": "I am happy because I am living my truth."
  },
  {
    "id": "e8442cca-5077-4970-9834-d71afffe0060",
    "speaker": "",
    "text": "My life is full of endless possibilities."
  },
  {
    "id": "37aa8483-a89c-42b5-9d9b-bfd641691fd6",
    "speaker": "",
    "text": "I can find the positives in any situation."
  },
  {
    "id": "835cc6d1-9dab-40c3-99ce-5ffed4e8d9c5",
    "speaker": "",
    "text": "Being perfect is impossible, and that's ok."
  },
  {
    "id": "874c513f-067b-4ec4-b2bf-40fa06917d9c",
    "speaker": "",
    "text": "I deserve to live a healthy and happy life."
  },
  {
    "id": "8d11ecdd-4a3b-4534-863e-5af422061b48",
    "speaker": "",
    "text": "I am happy to take steps toward my potential."
  },
  {
    "id": "263fa79f-062d-4a0f-ac1a-70e1ed28f84c",
    "speaker": "",
    "text": "I know that true happiness starts from within."
  },
  {
    "id": "78cf843a-d99b-41e1-8154-abdcda6294b7",
    "speaker": "",
    "text": "Thankfulness is the beginning of my happiness."
  },
  {
    "id": "c557b572-fd30-44d4-a026-3249b1810b5d",
    "speaker": "",
    "text": "I find myself in a state of perpetual happiness."
  },
  {
    "id": "1f47e782-28bf-4031-9cd3-51b1115792d3",
    "speaker": "",
    "text": "I no longer let people's opinion of me affect me."
  },
  {
    "id": "375e4ab3-71bc-49da-bb0c-0b560371d1a6",
    "speaker": "",
    "text": "I embrace the morning as a joyful start to my day."
  },
  {
    "id": "782d04b9-0373-4b4c-bd15-958092bc7afd",
    "speaker": "",
    "text": "I am surrounded by the warm, radiant vibes of joy."
  },
  {
    "id": "654d3d88-ef8a-4c71-950b-c850f5e91295",
    "speaker": "",
    "text": "I trust my decisions."
  },
  {
    "id": "54a04932-61ea-489a-b643-6e468f7705bf",
    "speaker": "",
    "text": "I am succeeding today."
  },
  {
    "id": "9ee4a01a-ff17-43cf-a6b7-6bd1f4a2cb70",
    "speaker": "",
    "text": "I am on the right path."
  },
  {
    "id": "06c11ae5-c80b-4ec4-afc0-66f929400710",
    "speaker": "",
    "text": "I know exactly who I am."
  },
  {
    "id": "5f12f88f-5322-404e-abbd-7273c00c7be3",
    "speaker": "",
    "text": "I am powerful beyond measure."
  },
  {
    "id": "d6cd0396-77b5-4248-b7d1-fe9dae46c0b9",
    "speaker": "",
    "text": "I am brimming with potential."
  },
  {
    "id": "e2fda10d-98cb-44b5-aeec-8b25f89ba753",
    "speaker": "",
    "text": "I see this as my chance to grow."
  },
  {
    "id": "4811b39f-734a-4d98-bc2c-2740347e21ff",
    "speaker": "",
    "text": "I challenge myself to keep going."
  },
  {
    "id": "45e647a5-d30f-4fe1-8f99-f3ea64f16771",
    "speaker": "",
    "text": "I find ways to improve every day."
  },
  {
    "id": "aabc4254-2de0-4879-91c2-09f318867ef2",
    "speaker": "",
    "text": "I embrace every aspect of my life."
  },
  {
    "id": "4b8b02a5-42f1-49eb-b1e6-9d6e7a1520ec",
    "speaker": "",
    "text": "I am in control of my own destiny."
  },
  {
    "id": "24817751-b315-45b4-be57-ffa6628f376f",
    "speaker": "",
    "text": "My opportunities for growth are endless."
  },
  {
    "id": "65007579-d815-45fa-9bab-350a29ad9aeb",
    "speaker": "",
    "text": "I am open to new ideas and perspectives."
  },
  {
    "id": "9e40a82c-c243-4337-80c9-52c0456c026f",
    "speaker": "",
    "text": "I enjoy exploring new skills and talents."
  },
  {
    "id": "1e19c929-9983-46a1-90c3-fc31616269fb",
    "speaker": "",
    "text": "I am a work in progress, and that's okay."
  },
  {
    "id": "097742b7-5761-4e62-9d12-4f7ebb97cd0e",
    "speaker": "",
    "text": "I allow myself to adapt, change, and grow."
  },
  {
    "id": "66992d05-a33c-4e6b-924c-007738897cda",
    "speaker": "",
    "text": "I can learn anything that I want to learn."
  },
  {
    "id": "48b92799-7f9d-479b-abbe-a6002b36bc86",
    "speaker": "",
    "text": "I find my strengths when I face adversity."
  },
  {
    "id": "63f0869d-9ddb-405a-b4d0-b0aa5d02ca5c",
    "speaker": "",
    "text": "I embrace change as a way of moving forward."
  },
  {
    "id": "ac5a61aa-34b9-4d5d-b20e-232af063cbbe",
    "speaker": "",
    "text": "I stand in the very happiness I have created."
  },
  {
    "id": "f59530ce-4e7f-404a-a0cd-0c7b04e33ace",
    "speaker": "",
    "text": "I face challenges with confidence and courage."
  },
  {
    "id": "e52f76cf-389d-41f5-b72f-fff4e44d0eb6",
    "speaker": "",
    "text": "I always surround myself with positive people."
  },
  {
    "id": "80304e73-d8fd-4819-becc-e905baa6c726",
    "speaker": "",
    "text": "I am deserving of love, happiness, and success."
  },
  {
    "id": "a4990c39-319a-48db-ac50-091f20188612",
    "speaker": "",
    "text": "I trust myself to create the life I want to live."
  },
  {
    "id": "1a7f68e4-36b4-4218-86e2-adeba52fbef5",
    "speaker": "",
    "text": "I realize how much I have changed for the better."
  },
  {
    "id": "99081b14-ec7b-4017-8582-98b0ccbe61d2",
    "speaker": "",
    "text": "I am confident in my ability to achieve my goals."
  },
  {
    "id": "480e2c43-9875-49c5-a456-35149cd50178",
    "speaker": "",
    "text": "I am constantly adding to my skills and abilities."
  },
  {
    "id": "a4190a8a-2e7e-49bc-960c-89c5e92f3a0c",
    "speaker": "",
    "text": "I am perfectly fine with being a work in progress."
  },
  {
    "id": "40d38fb3-025b-4762-ac86-8ef25a4c00a1",
    "speaker": "",
    "text": "I am worthy."
  },
  {
    "id": "d33eed40-f12a-4199-aa2c-49c8c306d7e1",
    "speaker": "",
    "text": "Today is a new start."
  },
  {
    "id": "a8c55933-f00e-4eb7-aafb-eb9a92827bc0",
    "speaker": "",
    "text": "I am trusting the journey."
  },
  {
    "id": "493a75db-3790-4fee-a317-3e73d84c935b",
    "speaker": "",
    "text": "I feel healthy and strong today."
  },
  {
    "id": "043bd164-4664-4129-9b02-f0fe21425797",
    "speaker": "",
    "text": "I am thankful for every new day."
  },
  {
    "id": "e2461595-a206-4f28-bd06-fbc7dc2f571a",
    "speaker": "",
    "text": "Today is a good day to be happy."
  },
  {
    "id": "769c62af-c068-43bf-9be8-9eff18684324",
    "speaker": "",
    "text": "I let go of any stress from today."
  },
  {
    "id": "c6225ee3-15c0-406f-b415-79aef581f8f2",
    "speaker": "",
    "text": "I am proud of how hard I am trying."
  },
  {
    "id": "18eb9a05-e435-454c-86c4-10404afed7dd",
    "speaker": "",
    "text": "I am happy and free because I am me."
  },
  {
    "id": "6120075d-26ca-4896-85a6-0325e8524c15",
    "speaker": "",
    "text": "I let my happiness transform my day."
  },
  {
    "id": "5c6a9dfe-b0f3-442e-bd64-fe49f9b76731",
    "speaker": "",
    "text": "I am accomplishing all of my dreams."
  },
  {
    "id": "5a4c9d44-644d-4429-b3f4-ba032f613883",
    "speaker": "",
    "text": "I am certain that today is wonderful."
  },
  {
    "id": "88468e8c-b479-403b-a134-ed6e2f3102d2",
    "speaker": "",
    "text": "I wake up each morning feeling energized."
  },
  {
    "id": "d47b6438-5c79-4d5f-9bab-7d9e575cbb2e",
    "speaker": "",
    "text": "I wake up today with strength in my heart."
  },
  {
    "id": "15f06a25-8fe5-467c-93ab-35776768ae88",
    "speaker": "",
    "text": "I choose to have a joyful and peaceful day."
  },
  {
    "id": "40953fe6-ca55-4232-8ac7-9cbb2c0e7292",
    "speaker": "",
    "text": "I am excited to see what I will learn today."
  },
  {
    "id": "6a0872f1-b462-4e70-9651-19dbc9a35169",
    "speaker": "",
    "text": "Every day I take action to achieve my goals."
  },
  {
    "id": "be323ce5-787b-4cf7-a67f-b46e4bc233bc",
    "speaker": "",
    "text": "I am in control of my life and my happiness."
  },
  {
    "id": "ac76e1c6-8b4f-4193-8e2c-51eaec22e2ad",
    "speaker": "",
    "text": "Today, I am happy, confident, and successful."
  },
  {
    "id": "50952a40-171d-4866-ae00-04e2c4f2e749",
    "speaker": "",
    "text": "I have done it before and I am doing it again."
  },
  {
    "id": "ac4368a2-aceb-4471-926d-564e8f42486e",
    "speaker": "",
    "text": "Today I embrace life in all its sadness and joy."
  },
  {
    "id": "2492aa8a-8f70-4359-918e-b640aaa238f3",
    "speaker": "",
    "text": "I am grateful to be awake and alive this new day."
  },
  {
    "id": "69e2e994-6b51-4a2d-a883-5c4a57216f26",
    "speaker": "",
    "text": "I am becoming more at ease with myself every day."
  },
  {
    "id": "401b1ff5-24c0-4c35-8251-51dcf1f95ca7",
    "speaker": "",
    "text": "My life is just beginning."
  },
  {
    "id": "3a9eeff6-2d69-40c0-a508-edcd8aa15dc0",
    "speaker": "",
    "text": "My potential is limitless."
  },
  {
    "id": "e7edb210-0680-4062-883b-dd7028e39ba9",
    "speaker": "",
    "text": "I am excited for my future."
  },
  {
    "id": "c30f7f49-f53e-43da-80d7-4a7510fb895d",
    "speaker": "",
    "text": "The life I want starts now."
  },
  {
    "id": "5cfece43-4e75-4cec-87e4-80448c38c0bb",
    "speaker": "",
    "text": "I am excited about my future."
  },
  {
    "id": "18bc8d8a-fc22-47c9-b619-e823ef63de90",
    "speaker": "",
    "text": "I work on my goals every day."
  },
  {
    "id": "e3dc675b-5d45-46e6-b1f3-5497b6d8587f",
    "speaker": "",
    "text": "I know what I want to do in life."
  },
  {
    "id": "3a608928-13db-47a0-ab55-dab84d32d570",
    "speaker": "",
    "text": "I am able to have a new beginning."
  },
  {
    "id": "09d247a2-9ae7-4d7b-b99e-2b1adf96af49",
    "speaker": "",
    "text": "I celebrate the wins, big and small."
  },
  {
    "id": "737eb8cc-a063-4808-9dcc-df453351f7bc",
    "speaker": "",
    "text": "I am brave enough to try new things."
  },
  {
    "id": "45a10dc2-44b7-4788-99f2-8a3e567d5823",
    "speaker": "",
    "text": "I relax and accept what is beginning."
  },
  {
    "id": "9e375b9c-5394-41e1-aae7-df348f67c840",
    "speaker": "",
    "text": "I am creating a better life for myself."
  },
  {
    "id": "dbe7901e-f4c5-4d75-88ec-f16651c9bc07",
    "speaker": "",
    "text": "I give myself the gift of a happy life."
  },
  {
    "id": "2d5acb2b-900c-476b-8dac-24e3289b5c54",
    "speaker": "",
    "text": "I navigate new beginnings successfully."
  },
  {
    "id": "26d933cf-89ee-4470-b455-3a45c7cf7c07",
    "speaker": "",
    "text": "I see my dreams beginning to take shape."
  },
  {
    "id": "6737901f-7a0b-450b-84a9-daa0ab26880f",
    "speaker": "",
    "text": "I only focus on what is beneficial for me."
  },
  {
    "id": "9a06b6a8-2ab3-4224-b438-00d4e023b0ac",
    "speaker": "",
    "text": "I open my heart and mind to new adventures."
  },
  {
    "id": "6b0a2f09-2492-4a30-ae87-3f4dd8eb86a8",
    "speaker": "",
    "text": "I see change as an opportunity to progress."
  },
  {
    "id": "e5d09347-720e-4049-adf4-88b0ce93919f",
    "speaker": "",
    "text": "I choose not to tolerate unhealthy behavior."
  },
  {
    "id": "f5ff6c13-183e-4e22-b1e9-45fdc6f9bb3e",
    "speaker": "",
    "text": "I know that growth is painful but necessary."
  },
  {
    "id": "84149609-26ff-43a7-8d02-84a34a03607b",
    "speaker": "",
    "text": "I am excited to start this new path in life."
  },
  {
    "id": "7136b4b4-b7c6-4645-8032-31845a5c692b",
    "speaker": "",
    "text": "I recognize the blessing of beginning fresh."
  },
  {
    "id": "20dbda24-3f8e-4c31-8b1e-8d26afe53a25",
    "speaker": "",
    "text": "I accept challenges as opportunities to grow."
  },
  {
    "id": "1e16c8da-586a-4fac-995d-539a0edd046f",
    "speaker": "",
    "text": "I build new healthy habits for a bright future."
  },
  {
    "id": "37d370d3-47db-45bc-8cf0-e2abf19b28c7",
    "speaker": "",
    "text": "I am excited for what's coming next in my life."
  },
  {
    "id": "b4a84163-85e7-4cde-9d88-5d091338659c",
    "speaker": "",
    "text": "I treat each day as a chance for a new beginning."
  },
  {
    "id": "d5ce60a4-4305-42f4-aee1-8834cada6065",
    "speaker": "",
    "text": "I am always at peace."
  },
  {
    "id": "9b572eb4-7db6-42d8-9812-fd1729d8d6de",
    "speaker": "",
    "text": "Everybody is imperfect."
  },
  {
    "id": "b881619a-59dd-4b63-97b1-c6f9a3c99cd5",
    "speaker": "",
    "text": "I listen to my breathing."
  },
  {
    "id": "79e90c1d-8479-4887-badf-1986d813a493",
    "speaker": "",
    "text": "I breathe in peace and joy."
  },
  {
    "id": "131f7a8a-5039-4960-af40-b903e9c304f9",
    "speaker": "",
    "text": "I welcome calm and serenity."
  },
  {
    "id": "e9430595-4207-4347-844e-9330a3e2dcf9",
    "speaker": "",
    "text": "I feel at peace with myself."
  },
  {
    "id": "5b7dd68c-767e-4edb-9c83-e6afde6363f3",
    "speaker": "",
    "text": "I choose to have calm energy."
  },
  {
    "id": "db2fa087-936c-4f80-a761-b61b62189086",
    "speaker": "",
    "text": "My mind is calm and at peace."
  },
  {
    "id": "38b4ad46-b160-4551-ac6b-79b284a5b53b",
    "speaker": "",
    "text": "I feel my tension dissolving."
  },
  {
    "id": "3d80a3c1-0ddb-4acc-bbbf-a7b7e7729cee",
    "speaker": "",
    "text": "I prioritize my ease and peace."
  },
  {
    "id": "540d9cd0-67ea-41a1-bd4c-0ff4343b819c",
    "speaker": "",
    "text": "I strive to have peace in my life."
  },
  {
    "id": "9a61fdd9-033e-4f61-aeff-6931d04416a2",
    "speaker": "",
    "text": "I radiate calm, peace, and serenity."
  },
  {
    "id": "9e20668d-dae1-434f-81fe-aacceafa31f2",
    "speaker": "",
    "text": "I live a life of gratitude and peace."
  },
  {
    "id": "dc36b4f2-bed3-4c90-9121-ebee795cadd6",
    "speaker": "",
    "text": "Calm is on the other side of my doubts."
  },
  {
    "id": "30ab9cd7-6220-4a5a-b427-ff004ac1e516",
    "speaker": "",
    "text": "I focus on living in the present moment."
  },
  {
    "id": "253125db-226d-4701-9159-c315535d18b9",
    "speaker": "",
    "text": "I am brave enough to show my true feelings."
  },
  {
    "id": "0fffc4d0-7824-4c3e-b96b-f977a119cbba",
    "speaker": "",
    "text": "I release my worries and allow myself peace."
  },
  {
    "id": "766d59be-4b3d-4c99-a5e1-46cdf5ec91b3",
    "speaker": "",
    "text": "I close my eyes and let my mind take flight."
  },
  {
    "id": "74d9b50e-4258-4219-aebb-66d7c9493cca",
    "speaker": "",
    "text": "Inside me lies a great reservoir of calmness."
  },
  {
    "id": "7323e728-4238-4883-999e-51349f2b9fdd",
    "speaker": "",
    "text": "I am living a harmonious and stress-free life."
  },
  {
    "id": "7d318647-b9ff-478c-906f-400b800597da",
    "speaker": "",
    "text": "I am in control of the direction of my journey."
  },
  {
    "id": "3b15da42-f3c0-4694-ba10-28b70c380d91",
    "speaker": "",
    "text": "I welcome calm, positive feelings into my heart."
  },
  {
    "id": "c8c9791c-c05a-40aa-9211-73892ffd5029",
    "speaker": "",
    "text": "I am peaceful, happy, healthy, and free to be me."
  },
  {
    "id": "528dfc00-0680-4260-b59e-a5325e4f6d43",
    "speaker": "",
    "text": "I forgive myself and others for not being perfect."
  },
  {
    "id": "d08ee2f4-3a16-479e-99f0-c7e2920d7b65",
    "speaker": "",
    "text": "I celebrate myself."
  },
  {
    "id": "d0bf7ce3-796d-467c-8cce-b17ef7657574",
    "speaker": "",
    "text": "I feel joy and ease today."
  },
  {
    "id": "c7284ac9-f834-4098-997b-a7316de17698",
    "speaker": "",
    "text": "Today is a fulfilling day."
  },
  {
    "id": "dbc2b222-4a4a-4567-8df1-d7a51339629b",
    "speaker": "",
    "text": "I deserve to enjoy myself."
  },
  {
    "id": "aba9226d-277f-4b0e-a605-590747534479",
    "speaker": "",
    "text": "I allow myself to feel good."
  },
  {
    "id": "aa7174fa-e98f-47c0-9b3e-38cd6449c3f0",
    "speaker": "",
    "text": "I deserve happiness and joy."
  },
  {
    "id": "6916385f-b51a-43da-a41e-ee725ecca6b5",
    "speaker": "",
    "text": "I am at peace within myself."
  },
  {
    "id": "49832f60-8a18-4b6b-a726-64fe59a9c81a",
    "speaker": "",
    "text": "Happiness is my true nature."
  },
  {
    "id": "41f435bc-ba4a-42df-88ff-1e2326f42bbb",
    "speaker": "",
    "text": "I focus on making myself happy."
  },
  {
    "id": "745298ae-15bd-47fc-b808-affc33568887",
    "speaker": "",
    "text": "Today, I choose positivity and peace."
  },
  {
    "id": "abdfa3d4-ae43-4477-81b9-120f1e78fa4c",
    "speaker": "",
    "text": "The world is full of happiness for me."
  },
  {
    "id": "c10560ab-7477-4b98-ba9e-7fe61a33a586",
    "speaker": "",
    "text": "I allow joy and happiness into my life."
  },
  {
    "id": "96f03ebc-264a-4295-8cc8-32e85024e346",
    "speaker": "",
    "text": "Happiness is my permanent state of mind."
  },
  {
    "id": "fa22240a-2ee1-410f-893b-18142b15ef53",
    "speaker": "",
    "text": "I appreciate my life and everyone in it."
  },
  {
    "id": "6e244b8e-3af6-4cdb-be16-b6d91b41cf5a",
    "speaker": "",
    "text": "I nourish my mind with positive thoughts."
  },
  {
    "id": "22313438-a380-42cd-9faa-9049f1b15d79",
    "speaker": "",
    "text": "I have everything I need for a happy life."
  },
  {
    "id": "6a8e0614-2091-47ec-8672-22010ceebf8c",
    "speaker": "",
    "text": "I live my life with gratitude and happiness."
  },
  {
    "id": "c7bed04c-48cd-4523-b1f4-f5b32e3ba8ea",
    "speaker": "",
    "text": "I am dedicated to my health and my happiness."
  },
  {
    "id": "fdb1b7a4-b5ca-408a-be1b-bc4b599f9981",
    "speaker": "",
    "text": "I am happy with the simple things in my life."
  },
  {
    "id": "d497bf94-5bec-4e62-a0c4-d6bb3456d518",
    "speaker": "",
    "text": "My life is full of things that make me happy."
  },
  {
    "id": "948a5897-5b37-43df-ae30-adea25720faa",
    "speaker": "",
    "text": "I allow my happiness to spill over onto others."
  },
  {
    "id": "1e2ee4ea-dc86-4e87-8452-6c1f23ba5073",
    "speaker": "",
    "text": "I deserve to be happy, today and every other day."
  },
  {
    "id": "53b86c07-9a89-4acd-bc69-6861fc5871f6",
    "speaker": "",
    "text": "I focus on creating happy feelings within myself."
  },
  {
    "id": "387806fd-65e9-4382-b3c2-8bae07ba8f44",
    "speaker": "",
    "text": "I am happy with the person I am transforming into."
  },
  {
    "id": "046f1137-4d43-4bfe-831b-e57c779db990",
    "speaker": "",
    "text": "I am highly motivated."
  },
  {
    "id": "e0f5ddcd-6b23-450a-b6de-a17bbd35ba30",
    "speaker": "",
    "text": "I pursue my goals relentlessly."
  },
  {
    "id": "90cfba60-3a0a-46ce-91c0-6cb14978f5c9",
    "speaker": "",
    "text": "I take things one day at a time."
  },
  {
    "id": "033a4912-49d9-45ab-bf0f-833be25573a3",
    "speaker": "",
    "text": "I always stay focused on my goals."
  },
  {
    "id": "89710c46-5c18-4507-b7d5-fc49fd79502b",
    "speaker": "",
    "text": "Every morning I manifest my dreams."
  },
  {
    "id": "ea3ea7e1-0cb4-45da-adce-ab0c60665d04",
    "speaker": "",
    "text": "I am a magnet for my dreams and goals."
  },
  {
    "id": "134fb0ad-1e91-4b3e-b6a7-9af90bfec115",
    "speaker": "",
    "text": "I chase my big dreams with all my heart."
  },
  {
    "id": "2f017c3e-e72b-4136-ad52-633f1c82f30a",
    "speaker": "",
    "text": "I am on the path to achieving my dreams."
  },
  {
    "id": "9a68b5fe-632a-475f-9a42-79c6a46c294d",
    "speaker": "",
    "text": "I know that my dreams deserve my efforts."
  },
  {
    "id": "755e9bf1-dad9-42c0-bdac-8d49926aa550",
    "speaker": "",
    "text": "My goals fill me with passion and purpose."
  },
  {
    "id": "b5fc1e92-19b0-4838-89bf-4802cb2872f0",
    "speaker": "",
    "text": "I set bigger goals as I develop new skills."
  },
  {
    "id": "cd3d8f1a-be8f-4b59-94f5-dd9fb7373c29",
    "speaker": "",
    "text": "I am challenged and inspired to meet my goals."
  },
  {
    "id": "17480846-af6b-4983-b559-6d617dc147a3",
    "speaker": "",
    "text": "I am grateful for the journey toward my goals."
  },
  {
    "id": "ece1c88f-e7e0-4e06-8167-ea14cd750f99",
    "speaker": "",
    "text": "I construct my achievements, slowly but surely."
  },
  {
    "id": "c84b56f2-7e62-48a9-9347-55b040d007fd",
    "speaker": "",
    "text": "I am proud of how hard I work towards my goals."
  },
  {
    "id": "f15c9a80-7926-45e1-b941-c2233356e54b",
    "speaker": "",
    "text": "I have a fire within me that propels me forward."
  },
  {
    "id": "a2bbe5f4-0f21-4634-8d24-1c88c7fff177",
    "speaker": "",
    "text": "I am excited to see who I become years from now."
  },
  {
    "id": "a998e08b-aa83-4239-8500-88200a612bac",
    "speaker": "",
    "text": "My unwavering faith is a magnet for all I desire."
  },
  {
    "id": "add8a864-619c-42e0-8d8e-cde3cac8d96a",
    "speaker": "",
    "text": "I am confident in my ability to achieve my goals."
  },
  {
    "id": "9a121aeb-08b7-4bf6-a08a-fc767c749aad",
    "speaker": "",
    "text": "I am committed to turning my dreams into reality."
  },
  {
    "id": "e70b73ba-1693-45b7-9a10-a004508987d6",
    "speaker": "",
    "text": "I am a doer."
  },
  {
    "id": "b417b12c-6b0b-4b97-944e-43eceb50e399",
    "speaker": "",
    "text": "I am thriving."
  },
  {
    "id": "791c8274-b703-4ee3-ad99-ac8200c581ed",
    "speaker": "",
    "text": "I make smart decisions."
  },
  {
    "id": "0cb00aa6-6da6-4ff4-93cf-b04672db3b5a",
    "speaker": "",
    "text": "I am ready to work hard."
  },
  {
    "id": "f0288fcf-96b0-4f60-95c2-cf91b3d30463",
    "speaker": "",
    "text": "I am ready for great success."
  },
  {
    "id": "a1ef1501-2e21-49b1-96dd-553ecd807719",
    "speaker": "",
    "text": "Good things are coming my way."
  },
  {
    "id": "4396248e-b779-4482-89ee-f5d04d20d60b",
    "speaker": "",
    "text": "I am in charge of my own success."
  },
  {
    "id": "e966f258-c566-4176-976f-6db7e8116bed",
    "speaker": "",
    "text": "I take risks to accomplish my goals."
  },
  {
    "id": "e8093be8-e59a-459e-8cee-f0c128861e2c",
    "speaker": "",
    "text": "I am committed to achieving my goals."
  },
  {
    "id": "87388cb2-3303-478c-b034-40a99fc6646e",
    "speaker": "",
    "text": "I strive for progress, not perfection."
  },
  {
    "id": "434b1aec-ccfa-4a0a-ae13-9f5bc9f0ec7b",
    "speaker": "",
    "text": "I am worthy of accomplishing great things."
  },
  {
    "id": "6d9c4d14-0398-4c25-9552-d38aba0c2075",
    "speaker": "",
    "text": "I see small steps forward as progress, too."
  },
  {
    "id": "271a9706-9230-456f-bb39-d98b0c02f496",
    "speaker": "",
    "text": "I withstand challenges with ease and grace."
  },
  {
    "id": "fdccf0d1-709f-4aa2-8f2b-4e22583cc9ed",
    "speaker": "",
    "text": "I apply my new skills and knowledge easily."
  },
  {
    "id": "a5007e5b-47f7-4b6a-9e6c-eedeff1e70e8",
    "speaker": "",
    "text": "There is nothing I am not able to overcome."
  },
  {
    "id": "bc784ceb-a6e8-4e8c-8dae-0e98866e67e7",
    "speaker": "",
    "text": "I do work that is meaningful and fulfilling."
  },
  {
    "id": "fa3a0be0-a594-4e5b-8beb-8b9a61523f55",
    "speaker": "",
    "text": "I maintain a positive mindset during the day."
  },
  {
    "id": "74bab330-8663-4d96-bc8c-e9ea0306d69d",
    "speaker": "",
    "text": "I take steps toward my goals every single day."
  },
  {
    "id": "01d68391-225d-4783-8bc5-7c9f278d8384",
    "speaker": "",
    "text": "I trust in my ability to make my dreams come true."
  },
  {
    "id": "738d98d4-92a8-492d-ad0b-01415eb705af",
    "speaker": "",
    "text": "I have strong willpower."
  },
  {
    "id": "2a200086-7347-4c3d-94e6-bb2e2c6b6a12",
    "speaker": "",
    "text": "Today is a productive day."
  },
  {
    "id": "54c04a33-e736-4efc-8450-b7a0dc22500c",
    "speaker": "",
    "text": "I am fueled by my passions."
  },
  {
    "id": "c13c80ed-a969-4087-a433-3b60eacb621f",
    "speaker": "",
    "text": "I am motivated from within."
  },
  {
    "id": "46c9c9dc-6624-4a0e-89f5-24de939a92f2",
    "speaker": "",
    "text": "I do what brings me happiness."
  },
  {
    "id": "c55aadda-48e5-4081-8cc4-6561a15cb233",
    "speaker": "",
    "text": "I am rewarded for my hard work."
  },
  {
    "id": "a67213ef-7699-4ce0-ac30-7c50214ac06f",
    "speaker": "",
    "text": "I succeed at achieving my goals."
  },
  {
    "id": "be843cc7-7943-4c65-a246-e2ac0d2e4859",
    "speaker": "",
    "text": "I am moving closer to my dreams."
  },
  {
    "id": "348b7bfc-baa2-40b6-9320-100328929e6a",
    "speaker": "",
    "text": "I am creating my greatest future."
  },
  {
    "id": "f56440bb-8a67-4d6f-b2ab-cf8edb077d51",
    "speaker": "",
    "text": "I align my goals with my passions."
  },
  {
    "id": "adbe4f24-276c-4506-947e-3d6e95a725b2",
    "speaker": "",
    "text": "I am empowered to manifest my dreams."
  },
  {
    "id": "0230b4c1-228e-4e17-aca8-3193435ac628",
    "speaker": "",
    "text": "I conquer challenges with every step."
  },
  {
    "id": "a3009572-5f19-416d-be55-307e610a27c7",
    "speaker": "",
    "text": "I have the capacity to reach my goals."
  },
  {
    "id": "3711901b-10ee-43b3-83c1-4ce4e938c7c2",
    "speaker": "",
    "text": "I am meant to achieve incredible things."
  },
  {
    "id": "97209d2f-19e2-4a9e-ade4-34ff123a5d90",
    "speaker": "",
    "text": "I am unstoppable in achieving my dreams."
  },
  {
    "id": "67130ec7-0909-4801-b283-07c4df5ca06a",
    "speaker": "",
    "text": "I have all the motivation I need within me."
  },
  {
    "id": "c3174f31-7e52-46fb-80d7-b8bf30b6b71b",
    "speaker": "",
    "text": "I overcome any obstacles put in front of me."
  },
  {
    "id": "ea988e67-726a-4c85-81b9-300286f1335f",
    "speaker": "",
    "text": "I hustle with consistency and determination."
  },
  {
    "id": "3178e627-de51-4c9a-b997-714a4fee61b6",
    "speaker": "",
    "text": "I am climbing to the top of my own mountain."
  },
  {
    "id": "31582787-9f74-406b-a590-160f0fc68bca",
    "speaker": "",
    "text": "I accomplish the goals that I set for myself."
  },
  {
    "id": "9e67aae0-a4c6-4423-bb7e-47b9cb06a87a",
    "speaker": "",
    "text": "Every mistake is a stepping stone to my goals."
  },
  {
    "id": "5d831f31-5f04-4fa1-bb4a-e6150da07349",
    "speaker": "",
    "text": "I am inspired by the progress I make each day."
  },
  {
    "id": "0013587a-a945-4262-9cbb-9be0c36a433b",
    "speaker": "",
    "text": "I have the ability to obtain unlimited success."
  },
  {
    "id": "18ea2fec-ffee-45d7-bd4e-2f911cee2db1",
    "speaker": "",
    "text": "I work hard to transform my dreams into reality."
  },
  {
    "id": "bc2aa0af-d626-4139-bcc0-bf495b59cb47",
    "speaker": "",
    "text": "I am seeing the amazing results of my hard work."
  },
  {
    "id": "878ee0e5-defd-40ed-9e3e-276a48baeaaa",
    "speaker": "",
    "text": "I am who I am."
  },
  {
    "id": "4f6f46fc-9e61-44f4-9442-542b7dca2d03",
    "speaker": "",
    "text": "My life is amazing."
  },
  {
    "id": "8c3e1750-bdd2-4087-b4f8-7522f80a920b",
    "speaker": "",
    "text": "I am assertive and strong."
  },
  {
    "id": "a0043ae2-e806-4b15-ad46-9381b9343cec",
    "speaker": "",
    "text": "I am grateful to be myself."
  },
  {
    "id": "4a885f9b-d185-4dbd-bcdd-654c25468894",
    "speaker": "",
    "text": "I am whatever I want to be."
  },
  {
    "id": "698bb616-497e-4e1f-b56a-210a363d0efc",
    "speaker": "",
    "text": "I am at peace with who I am."
  },
  {
    "id": "de7fea58-4920-45df-87ea-b1fefa40d1d3",
    "speaker": "",
    "text": "I am a wonderful human being."
  },
  {
    "id": "a934e2a5-7b33-41cf-ae75-a4d5cc9a90aa",
    "speaker": "",
    "text": "I recognize my own self-worth."
  },
  {
    "id": "1e3775f3-c9ea-4039-8159-bf087626da02",
    "speaker": "",
    "text": "I love myself unconditionally."
  },
  {
    "id": "fdcf170a-a15f-42ea-9620-d099d6632b34",
    "speaker": "",
    "text": "Life always gives me what I need."
  },
  {
    "id": "f11559b4-b44e-4c88-8923-c383a89ba5a4",
    "speaker": "",
    "text": "I choose presence over perfection."
  },
  {
    "id": "c5153ce5-f0c4-4390-ad93-ac46f56a2de2",
    "speaker": "",
    "text": "My light radiates to those around me."
  },
  {
    "id": "e2da4c58-b4a1-438c-b67a-ecf78170345c",
    "speaker": "",
    "text": "I follow my honesty and live in my truth."
  },
  {
    "id": "9e3d6f9b-1183-4cce-9d5c-7d926fbeef89",
    "speaker": "",
    "text": "I am wonderful even when I'm not perfect."
  },
  {
    "id": "86c263fb-7c11-4b60-a387-61c27cefbfcb",
    "speaker": "",
    "text": "I am strong, courageous, and independent."
  },
  {
    "id": "386339a6-30f3-4d48-a6f8-881df4f4649b",
    "speaker": "",
    "text": "I am always guided to what is best for me."
  },
  {
    "id": "f117012c-4b7e-4b39-a1bc-2650b861755a",
    "speaker": "",
    "text": "I have what I need to be who I want to be."
  },
  {
    "id": "8b637823-34eb-4700-898a-5b1a42833126",
    "speaker": "",
    "text": "I love myself and want myself to be happy."
  },
  {
    "id": "0d5765f3-10a4-4ca0-a387-5a98efa7a3bf",
    "speaker": "",
    "text": "I am open to the process of self-discovery."
  },
  {
    "id": "719d78b1-3161-4b61-9eda-208042060ab2",
    "speaker": "",
    "text": "I bounce back from setbacks with confidence."
  },
  {
    "id": "16fd257f-3321-420a-89a7-529ffca3a1f7",
    "speaker": "",
    "text": "I only compare myself to who I was yesterday."
  },
  {
    "id": "d8b41c7d-f5bb-4be3-b016-46f274d413fd",
    "speaker": "",
    "text": "I release myself from others' thoughts about me."
  },
  {
    "id": "3199d8de-a5c4-403a-bbbe-99a714e6c104",
    "speaker": "",
    "text": "I constantly seek ways to become a better person."
  },
  {
    "id": "71315240-f742-4bb5-bc7b-6056d89583b0",
    "speaker": "",
    "text": "I am a uniquely capable and talented human being."
  },
  {
    "id": "6a3a958a-b493-4f5b-a7d8-cee513a8e5ae",
    "speaker": "",
    "text": "I am able to get through anything and everything."
  },
  {
    "id": "46537088-8ce9-43ea-b56a-8741676b18c8",
    "speaker": "",
    "text": "I am deserving of the good things that come to me."
  }
]
